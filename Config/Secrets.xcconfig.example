// Copy this file to Secrets.xcconfig (gitignored) and fill in your own
// Supabase project's values from Settings -> API in the Supabase dashboard.
//
// xcconfig values can't contain "//" (read as a comment) so the URL's
// scheme separator is escaped as $() to keep it on one line.
SUPABASE_URL = https:$()/$()/YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY = your-anon-public-key
